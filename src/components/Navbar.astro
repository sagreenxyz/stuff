---
import { getCollection } from 'astro:content';
import { buildNavTree, entryToNavSection } from '../data/content';

const entries = await getCollection('sections');
const navSections = entries.map(entryToNavSection);
const topics = buildNavTree(navSections);
---
<nav class="navbar">
  <a href="/" class="navbar-brand">📚 OpenTextbook</a>
  <ul class="navbar-menu">
    {topics.map((topic) => (
      <li class="navbar-item">
        <button type="button">
          {topic.title}
          <span class="chevron"></span>
        </button>
        <div class="dropdown">
          {topic.books.map((book) => (
            <div class="dropdown-section">
              <div class="dropdown-header">{book.title}</div>
              {book.units.map((unit) => (
                <div class="dropdown-unit">
                  <div class="dropdown-unit-label">{unit.title}</div>
                  {unit.chapters.map((chapter) => (
                    <div class="dropdown-chapter">
                      <div class="dropdown-chapter-label">{chapter.title}</div>
                      {chapter.sections.map((section) => (
                        <a href={section.href}>{section.title}</a>
                      ))}
                    </div>
                  ))}
                </div>
              ))}
            </div>
          ))}
        </div>
      </li>
    ))}
    <li class="navbar-item">
      <a href="/prompt">Prompt</a>
    </li>
  </ul>
</nav>

<script>
  // Toggle dropdown menus on button click; close on outside click
  document.querySelectorAll('.navbar-item > button').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      const item = (e.currentTarget as HTMLElement).closest('.navbar-item');
      const isActive = item?.classList.contains('active');
      document.querySelectorAll('.navbar-item').forEach((el) => el.classList.remove('active'));
      if (!isActive) item?.classList.add('active');
    });
  });
  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('.navbar-item')) {
      document.querySelectorAll('.navbar-item').forEach((el) => el.classList.remove('active'));
    }
  });
</script>
