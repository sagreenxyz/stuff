---
import type { NavChapter } from '../data/content';

interface Props {
  prev: NavChapter | null;
  next: NavChapter | null;
}
const { prev, next } = Astro.props;
---
<nav class="pagination" aria-label="Chapter navigation">
  {prev ? (
    <a href={prev.href} class="prev-link">
      <span style="font-size:18px">←</span>
      <span>
        <span class="link-label">Previous</span><br />
        <span class="link-title">{prev.title}</span>
      </span>
    </a>
  ) : <span></span>}
  {next ? (
    <a href={next.href} class="next-link">
      <span>
        <span class="link-label">Next</span><br />
        <span class="link-title">{next.title}</span>
      </span>
      <span style="font-size:18px">→</span>
    </a>
  ) : <span></span>}
</nav>
