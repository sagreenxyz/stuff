---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
// Filter to only H2, H3, H4 (sections, subsections, sub-subsections)
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 4);
---
<aside class="sidebar">
  <h3>In This Chapter</h3>
  {filteredHeadings.length > 0 ? (
    <ul>
      {filteredHeadings.map((heading) => (
        <li class={`heading-depth-${heading.depth}`}>
          <a href={`#${heading.slug}`}>{heading.text}</a>
        </li>
      ))}
    </ul>
  ) : (
    <p style="padding:0 1rem;font-size:12px;color:#888">No headings found.</p>
  )}
</aside>

<script>
  const sidebarLinks = document.querySelectorAll<HTMLAnchorElement>('.sidebar a[href^="#"]');
  const headingEls = Array.from(sidebarLinks)
    .map((link) => {
      const id = link.getAttribute('href')?.replace('#', '');
      return id ? document.getElementById(id) : null;
    })
    .filter(Boolean) as HTMLElement[];

  if (headingEls.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            sidebarLinks.forEach((link) => link.classList.remove('active'));
            const activeLink = document.querySelector<HTMLAnchorElement>(
              `.sidebar a[href="#${entry.target.id}"]`
            );
            activeLink?.classList.add('active');
          }
        }
      },
      { rootMargin: '-20% 0px -60% 0px' }
    );
    headingEls.forEach((h) => observer.observe(h));
  }
</script>
