---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Pagination from '../components/Pagination.astro';
import type { Section, FlatSection } from '../data/content';

interface Props {
  title: string;
  topicSlug: string;
  bookSlug: string;
  unitSlug: string;
  chapterSlug: string;
  sectionSlug: string;
  topicTitle: string;
  bookTitle: string;
  unitTitle: string;
  chapterTitle: string;
  sectionTitle: string;
  sections: Section[];
  section: Section;
  prev: FlatSection | null;
  next: FlatSection | null;
}

const {
  title,
  topicSlug, bookSlug, unitSlug, chapterSlug, sectionSlug,
  topicTitle, bookTitle, unitTitle, chapterTitle, sectionTitle,
  sections, section, prev, next,
} = Astro.props;

const breadcrumbItems = [
  { label: topicTitle, href: `/${topicSlug}` },
  { label: bookTitle, href: `/${topicSlug}/${bookSlug}` },
  { label: unitTitle, href: `/${topicSlug}/${bookSlug}/${unitSlug}` },
  { label: chapterTitle, href: `/${topicSlug}/${bookSlug}/${unitSlug}/${chapterSlug}` },
  { label: sectionTitle },
];

const runningHead = `${bookTitle.toUpperCase().slice(0, 50)}`;
---
<BaseLayout title={title}>
  <Sidebar
    sections={sections}
    currentSectionSlug={sectionSlug}
    topicSlug={topicSlug}
    bookSlug={bookSlug}
    unitSlug={unitSlug}
    chapterSlug={chapterSlug}
  />
  <main class="main-content">
    <Breadcrumb items={breadcrumbItems} />
    <article class="apa-paper">
      <div class="running-head">
        <span>{runningHead}</span>
        <span class="page-num">1</span>
      </div>
      <div class="apa-content">
        <h1>{sectionTitle}</h1>
        <Fragment set:html={section.content} />
        {section.subsections.map((sub) => (
          <>
            <h2 id={sub.id}>{sub.title}</h2>
            <Fragment set:html={sub.content} />
            {sub.subsubsections?.map((subsub) => (
              <>
                <h3 id={subsub.id}>{subsub.title}</h3>
                <Fragment set:html={subsub.content} />
              </>
            ))}
          </>
        ))}
      </div>
    </article>
    <Pagination prev={prev} next={next} />
  </main>
</BaseLayout>
