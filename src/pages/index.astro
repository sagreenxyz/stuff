---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { buildNavTree, entryToNavSection } from '../data/content';

const entries = await getCollection('sections');
const navSections = entries.map(entryToNavSection);
const topics = buildNavTree(navSections);
---
<BaseLayout title="Home">
  <main style="flex:1; background:#e8e8e8;">
    <div class="home-hero">
      <h1>OpenTextbook</h1>
      <p>A comprehensive open-access academic resource covering Mathematics, Psychology, and more. Formatted in APA-7 journal style.</p>
    </div>
    <div class="topics-grid">
      {topics.map((topic) => (
        <div class="topic-card">
          <h2>{topic.title}</h2>
          {topic.books.map((book) => (
            <div style="margin-bottom:1rem">
              <strong style="font-size:14px">{book.title}</strong>
              {book.units.map((unit) => (
                <div style="margin-top:0.5rem">
                  <span style="font-size:11px;text-transform:uppercase;color:#888;letter-spacing:0.05em">{unit.title}</span>
                  {unit.chapters.map((chapter) => (
                    <div style="margin-top:0.25rem">
                      <span style="font-size:12px;font-weight:600;color:#555">{chapter.title}</span>
                      <ul>
                        {chapter.sections.map((section) => (
                          <li>
                            <a href={section.href}>{section.title}</a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              ))}
            </div>
          ))}
        </div>
      ))}
    </div>
  </main>
</BaseLayout>
