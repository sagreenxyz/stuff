---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { buildNavTree, entryToNavSection } from '../../data/content';

export async function getStaticPaths() {
  const entries = await getCollection('sections');
  const navSections = entries.map(entryToNavSection);
  const topics = buildNavTree(navSections);
  return topics.map((topic) => ({
    params: { topic: topic.slug },
    props: { topic },
  }));
}

const { topic } = Astro.props;
---
<BaseLayout title={topic.title}>
  <main class="main-content" style="width:100%">
    <Breadcrumb items={[{ label: topic.title }]} />
    <div class="apa-paper" style="min-height:auto">
      <div class="apa-content">
        <h1>{topic.title}</h1>
        <p class="no-indent">
          This section contains all books within the <strong>{topic.title}</strong> topic.
          Select a section below to begin reading.
        </p>
        {topic.books.map((book) => (
          <div style="margin-bottom:2em">
            <h2 style="color:inherit">{book.title}</h2>
            {book.units.map((unit) => (
              <div style="margin-bottom:1em">
                <h3 style="color:inherit">{unit.title}</h3>
                {unit.chapters.map((chapter) => (
                  <div style="margin-bottom:0.5em">
                    <h4 style="color:inherit">
                      <a href={`/${topic.slug}/${book.slug}/${unit.slug}/${chapter.slug}`}>{chapter.title}</a>
                    </h4>
                    <ul>
                      {chapter.sections.map((section) => (
                        <li>
                          <a href={section.href}>{section.title}</a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>
