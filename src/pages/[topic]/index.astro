---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { buildNavTree, entryToNavChapter } from '../../data/content';

export async function getStaticPaths() {
  const entries = await getCollection('chapters');
  const navChapters = entries.map(entryToNavChapter);
  const topics = buildNavTree(navChapters);
  return topics.map((topic) => ({
    params: { topic: topic.slug },
    props: { topic },
  }));
}

const { topic } = Astro.props;
---
<BaseLayout title={topic.title}>
  <main class="main-content" style="width:100%">
    <Breadcrumb items={[{ label: topic.title }]} />
    <div class="apa-paper" style="min-height:auto">
      <div class="apa-content">
        <h1>{topic.title}</h1>
        <p class="no-indent">
          This section contains all books within the <strong>{topic.title}</strong> topic.
          Select a chapter below to begin reading.
        </p>
        {topic.books.map((book) => (
          <div style="margin-bottom:2em">
            <h2 style="color:inherit">{book.title}</h2>
            {book.units.map((unit) => (
              <div style="margin-bottom:1em">
                <h3 style="color:inherit">{unit.title}</h3>
                <ul>
                  {unit.chapters.map((chapter) => (
                    <li>
                      <a href={chapter.href}>{chapter.title}</a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>
