---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { buildNavTree, entryToNavChapter } from '../../../data/content';

export async function getStaticPaths() {
  const entries = await getCollection('chapters');
  const navChapters = entries.map(entryToNavChapter);
  const topics = buildNavTree(navChapters);
  const paths = [];
  for (const topic of topics) {
    for (const book of topic.books) {
      paths.push({
        params: { topic: topic.slug, book: book.slug },
        props: { topic, book },
      });
    }
  }
  return paths;
}

const { topic, book } = Astro.props;
---
<BaseLayout title={`${book.title} — ${topic.title}`}>
  <main class="main-content" style="width:100%">
    <Breadcrumb items={[
      { label: topic.title, href: `/${topic.slug}` },
      { label: book.title },
    ]} />
    <div class="apa-paper" style="min-height:auto">
      <div class="apa-content">
        <h1>{book.title}</h1>
        <p class="no-indent">Part of the <a href={`/${topic.slug}`}>{topic.title}</a> collection.</p>
        {book.units.map((unit) => (
          <div style="margin-bottom:2em">
            <h2 style="color:inherit">{unit.title}</h2>
            <ul>
              {unit.chapters.map((chapter) => (
                <li>
                  <a href={chapter.href}>{chapter.title}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>
