---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../../components/Breadcrumb.astro';
import { topics } from '../../../../../data/content';

export async function getStaticPaths() {
  const paths = [];
  for (const topic of topics) {
    for (const book of topic.books) {
      for (const unit of book.units) {
        for (const chapter of unit.chapters) {
          paths.push({
            params: { topic: topic.slug, book: book.slug, unit: unit.slug, chapter: chapter.slug },
            props: { topic, book, unit, chapter },
          });
        }
      }
    }
  }
  return paths;
}

const { topic, book, unit, chapter } = Astro.props;
const firstSection = chapter.sections[0];
---
<BaseLayout title={`${chapter.title} — ${book.title}`}>
  <main class="main-content" style="width:100%">
    <Breadcrumb items={[
      { label: topic.title, href: `/${topic.slug}` },
      { label: book.title, href: `/${topic.slug}/${book.slug}` },
      { label: unit.title, href: `/${topic.slug}/${book.slug}/${unit.slug}` },
      { label: chapter.title },
    ]} />
    <div class="apa-paper" style="min-height:auto">
      <div class="apa-content">
        <h1>{chapter.title}</h1>
        <p class="no-indent">
          Unit: <a href={`/${topic.slug}/${book.slug}/${unit.slug}`}>{unit.title}</a> —
          Book: <a href={`/${topic.slug}/${book.slug}`}>{book.title}</a>
        </p>
        {firstSection && (
          <p class="no-indent" style="margin-top:1em">
            <a href={`/${topic.slug}/${book.slug}/${unit.slug}/${chapter.slug}/${firstSection.slug}`}
               style="background:#1a2e4a;color:white;padding:8px 16px;text-decoration:none;font-family:sans-serif;font-size:13px;border-radius:4px">
              Start Reading →
            </a>
          </p>
        )}
        <h2>Sections</h2>
        <ol>
          {chapter.sections.map((section) => (
            <li>
              <a href={`/${topic.slug}/${book.slug}/${unit.slug}/${chapter.slug}/${section.slug}`}>
                {section.title}
              </a>
              {section.subsections.length > 0 && (
                <ul>
                  {section.subsections.map((sub) => (
                    <li style="font-size:10pt">{sub.title}</li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ol>
      </div>
    </div>
  </main>
</BaseLayout>
