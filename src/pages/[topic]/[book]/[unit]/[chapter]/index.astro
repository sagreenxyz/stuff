---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../../components/Breadcrumb.astro';
import { buildNavTree, entryToNavSection } from '../../../../../data/content';

export async function getStaticPaths() {
  const entries = await getCollection('sections');
  const navSections = entries.map(entryToNavSection);
  const topics = buildNavTree(navSections);
  const paths = [];
  for (const topic of topics) {
    for (const book of topic.books) {
      for (const unit of book.units) {
        for (const chapter of unit.chapters) {
          paths.push({
            params: { topic: topic.slug, book: book.slug, unit: unit.slug, chapter: chapter.slug },
            props: { topic, book, unit, chapter },
          });
        }
      }
    }
  }
  return paths;
}

const { topic, book, unit, chapter } = Astro.props;
---
<BaseLayout title={`${chapter.title} — ${unit.title}`}>
  <main class="main-content" style="width:100%">
    <Breadcrumb items={[
      { label: topic.title, href: `/${topic.slug}` },
      { label: book.title, href: `/${topic.slug}/${book.slug}` },
      { label: unit.title, href: `/${topic.slug}/${book.slug}/${unit.slug}` },
      { label: chapter.title },
    ]} />
    <div class="apa-paper" style="min-height:auto">
      <div class="apa-content">
        <h1>{chapter.title}</h1>
        <p class="no-indent">From <a href={`/${topic.slug}/${book.slug}/${unit.slug}`}>{unit.title}</a>.</p>
        <ul>
          {chapter.sections.map((section) => (
            <li>
              <a href={section.href}>{section.title}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </main>
</BaseLayout>
