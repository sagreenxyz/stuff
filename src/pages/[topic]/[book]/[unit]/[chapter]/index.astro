---
import { getCollection } from 'astro:content';
import ChapterLayout from '../../../../../layouts/ChapterLayout.astro';
import { entryToNavChapter, buildNavTree, getChapterNav } from '../../../../../data/content';

export async function getStaticPaths() {
  const entries = await getCollection('chapters');
  const navChapters = entries.map(entryToNavChapter);
  // Sort globally for pagination (by topic, book, unit, then order within unit)
  navChapters.sort((a, b) => {
    const topicCmp = a.topicSlug.localeCompare(b.topicSlug);
    if (topicCmp !== 0) return topicCmp;
    const bookCmp = a.bookSlug.localeCompare(b.bookSlug);
    if (bookCmp !== 0) return bookCmp;
    const unitCmp = a.unitOrder - b.unitOrder;
    if (unitCmp !== 0) return unitCmp;
    return a.order - b.order;
  });

  return entries.map((entry) => {
    const navCh = entryToNavChapter(entry);
    const { prev, next } = getChapterNav(navChapters, navCh.href);
    return {
      params: {
        topic: navCh.topicSlug,
        book: navCh.bookSlug,
        unit: navCh.unitSlug,
        chapter: navCh.slug,
      },
      props: { entry, navCh, prev, next },
    };
  });
}

const { entry, navCh, prev, next } = Astro.props;
const { Content, headings } = await entry.render();
---
<ChapterLayout
  title={navCh.title}
  bookTitle={navCh.bookTitle}
  headings={headings}
  prev={prev}
  next={next}
>
  <h1>{navCh.title}</h1>
  <Content />
</ChapterLayout>
