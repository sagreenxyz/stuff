---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { buildNavTree, entryToNavSection } from '../../../../data/content';

export async function getStaticPaths() {
  const entries = await getCollection('sections');
  const navSections = entries.map(entryToNavSection);
  const topics = buildNavTree(navSections);
  const paths = [];
  for (const topic of topics) {
    for (const book of topic.books) {
      for (const unit of book.units) {
        paths.push({
          params: { topic: topic.slug, book: book.slug, unit: unit.slug },
          props: { topic, book, unit },
        });
      }
    }
  }
  return paths;
}

const { topic, book, unit } = Astro.props;
---
<BaseLayout title={`${unit.title} — ${book.title}`}>
  <main class="main-content" style="width:100%">
    <Breadcrumb items={[
      { label: topic.title, href: `/${topic.slug}` },
      { label: book.title, href: `/${topic.slug}/${book.slug}` },
      { label: unit.title },
    ]} />
    <div class="apa-paper" style="min-height:auto">
      <div class="apa-content">
        <h1>{unit.title}</h1>
        <p class="no-indent">From <a href={`/${topic.slug}/${book.slug}`}>{book.title}</a>.</p>
        <ul>
          {unit.chapters.map((chapter) => (
            <li>
              <a href={`/${topic.slug}/${book.slug}/${unit.slug}/${chapter.slug}`}>{chapter.title}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </main>
</BaseLayout>
