---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import { topics } from '../../../../data/content';

export async function getStaticPaths() {
  const paths = [];
  for (const topic of topics) {
    for (const book of topic.books) {
      for (const unit of book.units) {
        paths.push({
          params: { topic: topic.slug, book: book.slug, unit: unit.slug },
          props: { topic, book, unit },
        });
      }
    }
  }
  return paths;
}

const { topic, book, unit } = Astro.props;
---
<BaseLayout title={`${unit.title} — ${book.title}`}>
  <main class="main-content" style="width:100%">
    <Breadcrumb items={[
      { label: topic.title, href: `/${topic.slug}` },
      { label: book.title, href: `/${topic.slug}/${book.slug}` },
      { label: unit.title },
    ]} />
    <div class="apa-paper" style="min-height:auto">
      <div class="apa-content">
        <h1>{unit.title}</h1>
        <p class="no-indent">
          From <a href={`/${topic.slug}/${book.slug}`}>{book.title}</a>.
        </p>
        {unit.chapters.map((chapter) => (
          <div style="margin-bottom:2em">
            <h2>
              <a href={`/${topic.slug}/${book.slug}/${unit.slug}/${chapter.slug}`} style="color:inherit;text-decoration:none">
                {chapter.title}
              </a>
            </h2>
            <ul>
              {chapter.sections.map((section) => (
                <li>
                  <a href={`/${topic.slug}/${book.slug}/${unit.slug}/${chapter.slug}/${section.slug}`}>
                    {section.title}
                  </a>
                  {section.subsections.length > 0 && (
                    <ul>
                      {section.subsections.map((sub) => (
                        <li style="font-size:10pt; color:#555; font-family:sans-serif">
                          {sub.title}
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>
